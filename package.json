{
  "name": "@affinity-health/npi",
  "version": "1.1.0",
  "description": "A type-safe TypeScript client for the CMS NPPES NPI Registry API.",
  "keywords": [
    "cms",
    "healthcare",
    "npi",
    "nppes",
    "provider"
  ],
  "homepage": "https://github.com/affinity-health/npi#readme",
  "bugs": {
    "url": "https://github.com/affinity-health/npi/issues"
  },
  "license": "MIT",
  "author": "Affinity Health",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/affinity-health/npi.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check",
    "dev": "vp pack --watch",
    "smoke": "bun scripts/smoke.ts",
    "test": "vp test",
    "verify": "bun run check && bun run test && bun run build",
    "prepublishOnly": "bun run verify"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "7.0.2",
    "vite-plus": "0.2.5",
    "vitest": "4.1.10"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.14"
}
